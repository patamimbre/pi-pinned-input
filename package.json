{
  "name": "pi-pinned-input",
  "version": "0.1.0",
  "description": "Pi extension that pins a bounded, growing prompt editor to the bottom of the terminal while session history scrolls above it.",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "index.ts",
    "src",
    "config/config.example.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "pnpm --package=typescript@5.7.3 dlx tsc -p tsconfig.json",
    "build": "pnpm --package=typescript@5.7.3 dlx tsc -p tsconfig.json --noCheck",
    "lint": "pnpm typecheck",
    "test": "node --test test/*.test.cjs",
    "check": "pnpm lint && pnpm test && pnpm build",
    "package:dry-run": "pnpm pack --dry-run",
    "postinstall": "node -e \"const fs=require('fs'),cp=require('child_process'),p=require('path');const cwd=process.cwd();const normalized=cwd.split(p.sep).join('/');if(!normalized.includes('/.pi/agent/extensions/'))process.exit(0);const s=p.resolve(cwd,'../../scripts/patch-vulnerable-deps.mjs');if(!fs.existsSync(s))process.exit(0);const r=cp.spawnSync(process.execPath,[s,'--target',cwd,'--quiet'],{stdio:'inherit'});process.exit(r.status||0)\""
  },
  "packageManager": "pnpm@11.1.2",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pi-coding-agent",
    "pi-tui",
    "coding-agent",
    "pinned-input",
    "sticky-input",
    "floating-input",
    "chat-input",
    "terminal",
    "alternate-screen",
    "footer"
  ],
  "author": "German Castro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patamimbre/pi-pinned-input.git"
  },
  "bugs": {
    "url": "https://github.com/patamimbre/pi-pinned-input/issues"
  },
  "homepage": "https://github.com/patamimbre/pi-pinned-input#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0 || ^0.75.0 || ^0.77.0 || ^0.78.0 || ^0.79.0 || ^0.80.0",
    "@earendil-works/pi-tui": "^0.74.0 || ^0.75.0 || ^0.77.0 || ^0.78.0 || ^0.79.0 || ^0.80.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@earendil-works/pi-tui": "^0.80.3",
    "jiti": "^2.7.0"
  },
  "overrides": {
    "protobufjs": "7.6.3",
    "ws": "8.21.0"
  }
}
